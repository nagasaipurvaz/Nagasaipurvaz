# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── FHIR Server ──────────────────────────────────────────────────────────────
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_CLIENT_ID=your-client-id
FHIR_CLIENT_SECRET=your-client-secret
FHIR_SCOPE=patient/*.read launch/patient openid

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healthcare_genai
REDIS_URL=redis://localhost:6379/0

# ─── Security (HIPAA) ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-32-byte-random-hex
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── HIPAA Audit ──────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=./logs/hipaa_audit.jsonl
AUDIT_RETENTION_DAYS=2555

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
